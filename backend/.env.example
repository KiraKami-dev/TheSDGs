# Copy to .env and fill in. Never commit the real .env.

# Required for the Claude Haiku fallback (used automatically if the local
# Qwen endpoint is unreachable or errors), and for the analysis features.
ANTHROPIC_API_KEY=

# Local model served via Ollama over an SSH tunnel to ada (ssh -L 11434:localhost:11434 ada -N).
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen3.6:35b
ANTHROPIC_FALLBACK_MODEL=claude-haiku-4-5-20251001

# "qwen" (default): Qwen on ada first, Claude as fallback. "claude": skip ada, use Claude directly.
YSI_MODEL_BACKEND=qwen

AURELIA_DATA_DIR=data/raw
YSI_DB_PATH=data/processed/ysi.duckdb
